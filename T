	if AntiAFK_Aktif then
		ToggleButton.Text = "STATUS: AKTIF"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 180, 50) -- Berubah Hijau
		StatusLabel.Text = "Sistem dimulai..."
		
		-- Gagalkan tendangan AFK internal Roblox
		KoneksiIdle = LocalPlayer.Idled:Connect(function()
			VirtualUser:CaptureController()
			VirtualUser:ClickButton2(Vector2.new(0,0))
		end)
	else
		ToggleButton.Text = "STATUS: MATI"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Berubah Merah
		StatusLabel.Text = "Menunggu diaktifkan..."
		if KoneksiIdle then
			KoneksiIdle:Disconnect()
			KoneksiIdle = nil
		end
	end
end)
