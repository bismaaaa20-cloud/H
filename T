-- === FUNGSI UTAMA GAMEPLAY (LOGIKA) ===

local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer
local Kamera = workspace.CurrentCamera

-- Fungsi gerak karakter acak
local function gerakAcak()
	local karakter = LocalPlayer.Character
	if not karakter then return end
	local humanoid = karakter:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.Health > 0 then
		StatusLabel.Text = "Aksi: Karakter Berjalan..."
		local arahX = math.random(-1, 1)
		local arahZ = math.random(-1, 1)
		local arah = Vector3.new(arahX, 0, arahZ)
		if arah.Magnitude == 0 then arah = Vector3.new(0,0,1) end
		
		humanoid:Move(arah, true)
		task.wait(math.random(5, 12) / 10)
		humanoid:Move(Vector3.new(0,0,0), true)
	end
end

-- Fungsi putar kamera acak
local function kameraAcak()
	StatusLabel.Text = "Aksi: Memutar Kamera..."
	local x, y, z = Kamera.CFrame:ToOrientation()
	local rotasiBaruX = y + math.rad(math.random(-50, 50))
	local rotasiBaruY = x + math.rad(math.random(-10, 10))
	rotasiBaruY = math.clamp(rotasiBaruY, math.rad(-45), math.rad(45))
	
	local targetCFrame = CFrame.new(Kamera.CFrame.Position) * CFrame.fromOrientation(rotasiBaruY, rotasiBaruX, 0)
	local infoTween = TweenInfo.new(math.random(10, 18) / 10, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local animasi = TweenService:Create(Kamera, infoTween, {CFrame = targetCFrame})
	animasi:Play()
	animasi.Completed:Wait()
end

-- Fungsi lompat acak
local function lompatAcak()
	local karakter = LocalPlayer.Character
	if not karakter then return end
	local humanoid = karakter:FindFirstChildOfClass("Humanoid")
	if humanoid and math.random(1, 2) == 1 then
		StatusLabel.Text = "Aksi: Karakter Melompat!"
		humanoid.Jump = true
	end
end

-- Loop utama yang berjalan di latar belakang
task.spawn(function()
	while true do
		task.wait(1)
		if AntiAFK_Aktif then
			local variasiWaktu = math.random(-15, 15)
			local totalTunggu = INTERVAL_UTAMA + variasiWaktu
			
			for i = totalTunggu, 1, -1 do
				if not AntiAFK_Aktif then break end
				local m = math.floor(i / 60)
				local s = i % 60
				StatusLabel.Text = string.format("Jeda aksi: %02d:%02d", m, s)
				task.wait(1)
			end
			
			if AntiAFK_Aktif then
				gerakAcak()
				task.wait(0.5)
				kameraAcak()
				task.wait(0.5)
				lompatAcak()
			end
		end
	end
end)

